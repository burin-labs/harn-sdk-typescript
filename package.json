{
  "name": "@burin-labs/harn",
  "version": "0.1.0-alpha.0",
  "description": "TypeScript SDK for the Harn Agents API",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "spec/openapi.yaml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:examples": "tsc --noEmit --target ES2022 --module ESNext --moduleResolution bundler --lib ES2022,DOM,DOM.Iterable --types node --strict examples/*.ts",
    "generate:types": "openapi-typescript spec/openapi.yaml -o src/generated/openapi.ts",
    "prepack": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/burin-labs/harn-sdk-typescript.git"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^25.6.0",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
