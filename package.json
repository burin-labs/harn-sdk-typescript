{
  "name": "@burin-labs/harn",
  "version": "0.1.0-alpha.0",
  "description": "TypeScript SDK for the Harn Agents API",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "spec/openapi.yaml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:examples": "tsc --noEmit --target ES2022 --module ESNext --moduleResolution bundler --lib ES2022,DOM,DOM.Iterable --types node --strict examples/*.ts",
    "check:tests": "tsc --noEmit --target ES2022 --module ESNext --moduleResolution bundler --lib ES2022,DOM,DOM.Iterable --types node --strict test/*.ts",
    "generate:types": "openapi-typescript spec/openapi.yaml -o src/generated/openapi.ts",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "pnpm build",
    "publish:alpha": "npm publish --access public --tag alpha",
    "publish:latest": "npm publish --access public --tag latest",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "version:alpha": "npm version prerelease --preid alpha",
    "version:major": "npm version major",
    "version:minor": "npm version minor",
    "version:patch": "npm version patch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/burin-labs/harn-sdk-typescript.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^25.9.1",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
